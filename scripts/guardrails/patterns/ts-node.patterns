# ts-node.patterns --- TypeScript/Node guardrail rules
# Format: RULE|GLOB|REGEX|MODE
# Applied when stack is ts-node (package.json present)

# IF-01: No framework imports in domain center
IF-01|domain/**/*.ts|import.*from\s+['"](express|@nestjs|typeorm|prisma|sequelize|knex|mongoose)|block
IF-01|domain/**/*.ts|require\s*\(\s*['"](express|@nestjs|typeorm|prisma|sequelize|knex|mongoose)|block

# IF-02: No SQL string concatenation (injection risk)
IF-02|**/*.ts|['"`].*\b(SELECT|INSERT|UPDATE|DELETE)\b.*['"`]\s*\+|block
IF-02|**/*.ts|\+\s*['"`].*\b(SELECT|INSERT|UPDATE|DELETE|FROM|WHERE)\b|block

# IF-03: No null returns from repository/store functions
IF-03|**/*Store*.ts|return\s+null|block
IF-03|**/*Repository*.ts|return\s+null|block
IF-03|**/*store*.ts|return\s+null|block
IF-03|**/*repository*.ts|return\s+null|block

# IF-04: Internal data structures leaked through public API (heuristic)
IF-04|**/*Controller*.ts|return\s+.*entity\b|advisory
IF-04|**/*controller*.ts|return\s+.*entity\b|advisory

# IF-05: Internal error details leaked in response objects
IF-05|**/*Controller*.ts|(stack|trace|internal|exception)\s*:|advisory
IF-05|**/*controller*.ts|(stack|trace|internal|exception)\s*:|advisory
IF-05|**/*Handler*.ts|(stack|trace|internal|exception)\s*:|advisory

# IF-06: Mutable fields in event/request/response objects (non-readonly fields with semicolons)
IF-06|**/*Event*.ts|\w+\s*:\s*\w+\s*;|advisory
IF-06|**/*Request*.ts|\w+\s*:\s*\w+\s*;|advisory
IF-06|**/*Response*.ts|\w+\s*:\s*\w+\s*;|advisory

# IF-07: Business logic in controller files
IF-07|**/*Controller*.ts|\bif\s*\(.*\.\w+\s*(===|!==|>|<|>=|<=).*\)|advisory
IF-07|**/*controller*.ts|\bif\s*\(.*\.\w+\s*(===|!==|>|<|>=|<=).*\)|advisory

# IF-08: Test without assertions
IF-08|**/*.test.ts|\bit\s*\([^)]*,\s*(async\s+)?\(\)\s*=>\s*\{[^}]*\}\s*\)|block
IF-08|**/*.spec.ts|\bit\s*\([^)]*,\s*(async\s+)?\(\)\s*=>\s*\{[^}]*\}\s*\)|block

# IF-09: Skipped/disabled tests
IF-09|**/*.test.ts|(xit|xdescribe)\(|block
IF-09|**/*.test.ts|(it|describe|test)\.skip|block
IF-09|**/*.spec.ts|(xit|xdescribe)\(|block
IF-09|**/*.spec.ts|(it|describe|test)\.skip|block

# IF-10: Hardcoded string literals in test assertions (magic values)
IF-10|**/*.test.ts|expect\(.*\)\.(toBe|toEqual)\s*\(\s*['"][a-zA-Z0-9 ]{10,}['"]\s*\)|advisory
IF-10|**/*.spec.ts|expect\(.*\)\.(toBe|toEqual)\s*\(\s*['"][a-zA-Z0-9 ]{10,}['"]\s*\)|advisory

# IF-11: Partial field sync --- field added in one place but not others (heuristic)
IF-11|**/*.ts|\/\/\s*FIELD[-_]?SYNC|advisory

# IF-12: Untested code change (heuristic --- new export without test)
IF-12|**/*.ts|\/\/\s*NO[-_]?TEST|advisory

# IF-13: Direct DB driver imports in domain center
IF-13|domain/**/*.ts|import.*from\s+['"]pg['"]|block
IF-13|domain/**/*.ts|import.*from\s+['"]mysql|block
IF-13|domain/**/*.ts|import.*from\s+['"]mongodb|block
IF-13|domain/**/*.ts|import.*from\s+['"]redis|block
IF-13|domain/**/*.ts|import.*from\s+['"]sqlite|block
IF-13|domain/**/*.ts|require\s*\(\s*['"]pg['"]\)|block

# IF-15: Router path without /api/ prefix (matches paths like '/users' but not '/api/')
IF-15|**/*.ts|\.(get|post|put|delete|patch)\s*\(\s*['"]/[b-z]|block
IF-15|**/*.ts|\.(get|post|put|delete|patch)\s*\(\s*['"]/(a[^p]|a$)|block

# IF-16: Handler without input validation (heuristic)
IF-16|**/*Controller*.ts|(req\.body|req\.params|req\.query)\b|advisory
IF-16|**/*controller*.ts|(req\.body|req\.params|req\.query)\b|advisory

# IF-17: Exported function without corresponding test (heuristic)
IF-17|src/**/*.ts|export\s+(async\s+)?function\s+\w+|advisory

# IF-19: Generic catch without type narrowing
IF-19|**/*.ts|catch\s*\(\s*\w+\s*\)\s*\{|block

# IF-20: Empty catch block (swallowed errors)
IF-20|**/*.ts|catch\s*\(\s*\w+\s*\)\s*\{\s*\}|block
