# Minimal sshd for the sandbox builder.
# Non-privileged port so sshd never needs root or CAP_NET_BIND_SERVICE.
# Pubkey-only; the keypair is generated by the keys-init service on the
# host and mounted in as id_ed25519(.pub).

Port 2222
AddressFamily inet
ListenAddress 0.0.0.0

# Host keys live under /home/builder/.ssh/ so a non-root sshd can read them.
# Generated at container start by entrypoint.sh if missing.
HostKey /home/builder/.ssh/ssh_host_ed25519_key

PermitRootLogin no
PasswordAuthentication no
ChallengeResponseAuthentication no
KbdInteractiveAuthentication no
UsePAM no
PubkeyAuthentication yes
AuthorizedKeysFile /home/builder/.ssh/authorized_keys

AllowUsers builder
PermitEmptyPasswords no
PermitUserEnvironment no
X11Forwarding no
AllowTcpForwarding no
AllowAgentForwarding no
GatewayPorts no
PrintMotd no

# Mirror agent ~/.ssh/config's SendEnv — only build-tuning vars cross
# the boundary, nothing path- or auth-related.
AcceptEnv MAVEN_OPTS MAVEN_ARGS GRADLE_OPTS JAVA_OPTS

# Set DOCKER_HOST for every session sshd opens. Testcontainers and
# anything else that respects DOCKER_HOST will route through the
# filtered docker-proxy automatically. The container's process env
# *does* have this set (via compose), but sshd-opened shells don't
# inherit it — sshd starts the user shell with a near-empty env, and
# we run with `UsePAM no` so /etc/environment isn't read either.
# SetEnv plugs that gap in one place.
SetEnv DOCKER_HOST=tcp://docker-proxy:2375

# Surface logs on stderr so `docker logs` shows auth events.
LogLevel INFO
SyslogFacility AUTH

# sshd needs a writable pid file path; entrypoint sets one under $HOME.
PidFile /home/builder/.ssh/sshd.pid

Subsystem sftp internal-sftp
