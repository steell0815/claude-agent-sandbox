# Copy to .env and adjust as needed. Anything left unset uses the
# built-in default visible in docker-compose.yml.

# --- Auth ----------------------------------------------------------------
# Headless / API-only billing. Comment out to fall back to the credential
# file mounted from ~/.claude/.credentials.json on the host.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Image pinning -------------------------------------------------------
# Pin Claude Code to a specific npm tag for reproducible rebuilds.
# CLAUDE_CODE_VERSION=1.2.3

# --- Proxy policy --------------------------------------------------------
# Path (inside the proxy container) to a file with extra host regexes,
# one per line. Comments (#) and blank lines are ignored.
# To wire one in, add a `volumes:` entry to the proxy service that mounts
# your file at e.g. /etc/proxy/allowlist.txt and set:
# ALLOWLIST_EXTRA=/etc/proxy/allowlist.txt
# DLP_EXTRA=/etc/proxy/dlp.txt

# --- Audit log -----------------------------------------------------------
# 50 MiB per file, 10 rotations = 500 MiB ceiling.
# AUDIT_MAX_BYTES=52428800
# AUDIT_BACKUPS=10

# --- Resource caps -------------------------------------------------------
# AGENT_MEM_LIMIT=4g
# AGENT_CPUS=2
