# Hardened agent image. Multi-stage so a future agent-ide stage can share
# the base layers without bloating the one-shot path.
#
# Build context is the repo root so that the public CA cert under ./ca
# (generated by the proxy-init service) can be COPY'd in at build time.

# hadolint ignore=DL3007
FROM node:22-bookworm-slim AS agent-base

ARG CA_CERT_PATH=ca/mitmproxy-ca-cert.pem
ARG CLAUDE_CODE_VERSION=latest

# hadolint ignore=DL3008,DL3009
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates \
      git \
      curl \
      python3 \
      jq \
      tini \
      openssh-client \
 && rm -rf /var/lib/apt/lists/*

# Bake the proxy CA as a system trust anchor so npm/pip/git/curl/the
# Anthropic SDK all honor it without per-process configuration.
COPY ${CA_CERT_PATH} /usr/local/share/ca-certificates/mitm.crt
RUN update-ca-certificates

# Install Claude Code globally before dropping privileges.
RUN npm install -g "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" \
 && npm cache clean --force

# node:22-bookworm-slim ships with a `node` user/group at uid/gid 1000; reuse
# the slot rather than collide on it.
RUN userdel --remove node \
 && groupadd --gid 1000 agent \
 && useradd --create-home --uid 1000 --gid 1000 --shell /bin/bash agent

# Claude Code rewrites ~/.claude.json on every session. It sits at the
# home-dir level (sibling of ~/.claude), so it's not covered by the
# ~/.claude:ro bind mount or any of the tmpfs overlays under it — and
# the read-only rootfs would EROFS the first write.
#
# Redirect it into /home/agent/sandbox-state, which docker-compose.yml
# backs with a named volume so onboarding flags, trusted-directory
# decisions, theme, and project history persist across container runs.
# The mountpoint dir is created here at build time because the read-only
# rootfs blocks runtime mkdir for new mountpoints.
RUN install -d -o agent -g agent /home/agent/sandbox-state \
 && ln -s /home/agent/sandbox-state/claude.json /home/agent/.claude.json \
 && chown -h agent:agent /home/agent/.claude.json

# SSH config so the agent can shell into the builder service via
# `ssh builder mvn ...`. The private key is mounted at runtime from the
# builder-keys volume populated by the keys-init service.
RUN install -d -o agent -g agent -m 0700 /home/agent/.ssh \
 && install -d -o agent -g agent -m 0755 /run/builder-keys
COPY --chown=agent:agent agent/ssh-config /home/agent/.ssh/config
RUN chmod 600 /home/agent/.ssh/config

ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt \
    REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt \
    SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt \
    GIT_SSL_CAINFO=/etc/ssl/certs/ca-certificates.crt \
    HTTP_PROXY=http://proxy:8080 \
    HTTPS_PROXY=http://proxy:8080 \
    NO_PROXY=localhost,127.0.0.1

COPY agent/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER agent
WORKDIR /workspace

# ----------------------------------------------------------------------------
# Phase 1 stage: lean one-shot agent. IDE-mode stage (agent-ide) lands later.
# ----------------------------------------------------------------------------
FROM agent-base AS agent
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/entrypoint.sh"]
CMD []
