{
  "//": "Sandbox-side Claude Code settings, loaded via --settings in entrypoint.sh. Hosts the harness-level enforcement that lives outside the LLM (PreToolUse hooks etc.). Keep this file minimal — anything project-specific belongs in /workspace/.claude/settings.json.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/block-docker-cli.sh"
          },
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/block-apt-install.sh"
          },
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/block-node-global-install.sh"
          },
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/block-pip-install.sh"
          },
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/block-cargo-install.sh"
          },
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/block-go-install.sh"
          },
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/block-gem-install.sh"
          },
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/block-pipe-to-shell.sh"
          }
        ]
      }
    ]
  }
}
